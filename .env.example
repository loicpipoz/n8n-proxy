# Tailscale
TS_AUTHKEY=tskey-auth-REPLACE_ME
TAILSCALE_VERSION=latest
TAILSCALE_HOSTNAME=n8n-proxy
TS_EXTRA_ARGS="--advertise-tags=tag:webhook-proxy --accept-dns=true"

# Public hostname handled by Caddy. Do not include a port here.
PUBLIC_DOMAIN=hooks.example.com

# Caddy site address. Use PUBLIC_DOMAIN when Caddy terminates public TLS.
# Use :80 when another reverse proxy, such as Nginx Proxy Manager, terminates TLS.
CADDY_SITE_ADDRESS=hooks.example.com

# Private n8n target reachable from the proxy through the tailnet.
N8N_UPSTREAM_URL=https://n8n-prod.your-tailnet.ts.net

# Host header and TLS SNI used when proxying to n8n. If N8N_UPSTREAM_URL uses
# an IP, keep these set to the original n8n hostname.
N8N_UPSTREAM_HOST=n8n-prod.your-tailnet.ts.net
N8N_UPSTREAM_TLS_SERVER_NAME=n8n-prod.your-tailnet.ts.net

# Webhook allowlist. Keep this narrow; all other paths return 404.
WEBHOOK_METHODS=POST
WEBHOOK_PATHS="/webhook/stripe/* /webhook/github/*"

# n8n Form Trigger and form resume allowlist. Forms are browser-facing, so GET
# is needed to render pages and POST is needed to submit them.
FORM_METHODS="GET POST"
FORM_PATHS="/form/* /form-test/* /form-waiting/*"

# Replace this with provider CIDRs when available. Leave public only when
# the webhook provider cannot publish stable source IP ranges.
ALLOWED_SOURCE_CIDRS="0.0.0.0/0 ::/0"

# Request body limit before proxying to n8n.
MAX_BODY_SIZE=10MB

# Internal path used by Caddy. Keep this unless you change the volume mount.
CADDY_LOG_DIR=/var/log/caddy

# Host bind addresses for public HTTP/HTTPS.
HTTP_BIND=0.0.0.0
HTTPS_BIND=0.0.0.0

# Host ports exposed by this proxy. Change these if another service already
# binds 80/443 on the server.
HTTP_PORT=80
HTTPS_PORT=443
